# .env for the weather bot — copy to repo-root .env on the NEW box and fill REAL values.
# .env is gitignored, so it does NOT travel via git — you recreate it by hand.
#
# CRITICAL: pydantic-settings makes .env OVERRIDE config.py. The live KELLY_FRACTION
# MUST be set here, or config.py's default silently wins. (This bit us once already.)

# Database — SQLite is the single source of truth (the DB file is scp'd over separately).
DATABASE_URL=sqlite:///./tradingbot.db

# Simulation — keep True until the live-execution path is built AND gated.
SIMULATION_MODE=True
INITIAL_BANKROLL=10000

# Position sizing — the HALVED production value. Do not change without restarting the eval clock.
KELLY_FRACTION=0.05

# Kalshi — deferred / disabled. If KALSHI_PRIVATE_KEY_PATH is set, scp that key file over too.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENABLED=False
